+
+        if jira_configured and ctx.jira_key and not ctx.jira_key.startswith("DEMO"):
+            yield send_event("step", {"step": "jira_update", "status": "running", "message": f"Updating Jira ticket {ctx.jira_key}..."})
+            try:
+                jira_result = update_jira(
