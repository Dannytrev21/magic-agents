+      description: 'Failure: Resource not found'
+      verification_type: test_result
+    - ref: REQ-001.INV-001
+      description: 'Invariant: Never expose password, passwordHash, ssn, or internalId
+        in API responses'
+      verification_type: test_result
+    - ref: REQ-001.INV-002
+      description: 'Invariant: Never allow cross-tenant data access'
+      verification_type: test_result
