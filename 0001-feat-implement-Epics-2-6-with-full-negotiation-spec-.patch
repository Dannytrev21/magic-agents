+                 "status": "passed", "failure_message": ""},
+                {"name": "Reject without auth[REQ-001.FAIL-001]",
+                 "classname": "Dog API", "tags": ["REQ-001.FAIL-001"],
+                 "status": "passed", "failure_message": ""},
