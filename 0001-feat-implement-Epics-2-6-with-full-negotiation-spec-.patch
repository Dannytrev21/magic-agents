+requirements:
+- id: REQ-001
+  ac_checkbox: 0
+  ac_text: User can list all dogs via GET /api/v1/dogs
+  title: User can list all dogs via GET /api/v1/dogs
+  type: api_behavior
+  contract:
+    interface:
+      method: GET
+      path: /api/v1/dogs
+      auth: jwt_bearer
+    preconditions:
+    - id: PRE-001
+      description: Valid JWT bearer token is present
+      formal: jwt != null AND jwt.exp > now()
+      category: authentication
+    - id: PRE-002
+      description: Resource referenced by path exists
+      formal: db.resource.exists(path.id) == true
+      category: data_existence
+    - id: PRE-003
+      description: User has access to the resource
+      formal: resource.owner == jwt.sub OR jwt.role == 'admin'
+      category: authorization
+    success:
+      status: 200
+      content_type: application/json
+      schema:
+        type: object
+        required:
+        - id
+        - name
+        - breed
+        properties:
+          id:
+            type: integer
+          name:
+            type: string
+          breed:
+            type: string
+          age:
+            type: integer
+        forbidden_fields:
+        - password
+        - internalId
+        - ssn
+    failures:
+    - id: FAIL-001
+      when: No auth token provided
+      violates: PRE-001
+      status: 401
+      body:
+        error: unauthorized
+        message: Bearer token required
+    - id: FAIL-002
+      when: Auth token expired
+      violates: PRE-001
+      status: 401
+      body:
+        error: unauthorized
+        message: Token expired
+    - id: FAIL-003
+      when: Resource not found
+      violates: PRE-002
+      status: 404
+      body:
+        error: not_found
+        message: Resource not found
+    invariants:
+    - id: INV-001
+      type: security
+      rule: Never expose password, passwordHash, ssn, or internalId in API responses
+      formal: Never expose password, passwordHash, ssn, or internalId in API responses
+    - id: INV-002
+      type: security
+      rule: Never allow cross-tenant data access
+      formal: Never allow cross-tenant data access
+    - id: INV-003
+      type: security
+      rule: All PII fields must have X-Data-Classification header
+      formal: All PII fields must have X-Data-Classification header
+    - id: INV-004
+      type: security
+      rule: 'Response MUST NOT contain fields: internalId, password, ssn'
+      formal: '''password'' not in response.keys() AND ''internalId'' not in response.keys()
+        AND ''ssn'' not in response.keys()'
+  verification:
+  - refs:
+    - success
+    - FAIL-001
