+            except Exception as e:
+                yield send_event("step", {"step": "jira_update", "status": "error", "message": str(e)})
+        else:
+            yield send_event("step", {"step": "jira_update", "status": "skipped", "message": "Jira update skipped (not configured or demo ticket)"})
