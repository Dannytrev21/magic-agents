+async function runPipeline() {
+  const btn = document.getElementById('btnPipeline');
+  const status = document.getElementById('pipelineStatus');
+  btn.disabled = true;
+  status.textContent = 'Starting pipeline...';
+  status.className = 'action-status';
+
+  const panel = document.getElementById('pipelinePanel');
+  panel.classList.remove('hidden');
+  const log = document.getElementById('pipelineLog');
+  log.innerHTML = '';
+
+  function addLogEntry(icon, message, className) {
+    const entry = document.createElement('div');
+    entry.className = 'evidence-row';
+    entry.innerHTML = `<span class="evidence-dot ${className}"></span> <span style="font-size:12px">${message}</span>`;
+    log.appendChild(entry);
+    log.scrollTop = log.scrollHeight;
+  }
+
+  try {
+    const res = await fetch('/api/pipeline/stream', { method: 'POST' });
+    const reader = res.body.getReader();
+    const decoder = new TextDecoder();
+    let buffer = '';
+
+    while (true) {
+      const { done, value } = await reader.read();
+      if (done) break;
+
+      buffer += decoder.decode(value, { stream: true });
+      const lines = buffer.split('\n');
+      buffer = lines.pop();
+
+      for (const line of lines) {
+        if (!line.startsWith('data: ')) continue;
+        try {
+          const data = JSON.parse(line.slice(6));
+          if (data.type === 'step') {
+            const icons = { running: '', done: 'pass', error: 'fail', skipped: '' };
+            const prefix = data.status === 'running' ? '<span class="spinner"></span>' : '';
+            addLogEntry(
+              icons[data.status],
+              `${prefix}<strong>${data.step}</strong>: ${data.message}`,
+              icons[data.status] || ''
+            );
+            status.textContent = `${data.step}: ${data.message}`;
+
+            // Show verdicts if available
+            if (data.step === 'evaluate' && data.status === 'done' && data.verdicts) {
+              renderVerdicts(data.verdicts, data.all_passed);
+            }
+          } else if (data.type === 'done') {
+            if (data.success) {
+              status.textContent = data.all_passed ? 'Pipeline complete — ALL PASSED' : 'Pipeline complete — SOME FAILED';
+              status.className = data.all_passed ? 'action-status ok' : 'action-status fail';
+              addLogEntry('', `<strong>Pipeline complete: ${data.all_passed ? 'ALL PASSED' : 'SOME FAILED'}</strong>`, data.all_passed ? 'pass' : 'fail');
+            } else {
+              status.textContent = 'Pipeline failed: ' + (data.error || 'unknown');
+              status.className = 'action-status fail';
+              addLogEntry('', `<strong>Pipeline failed</strong>: ${data.error}`, 'fail');
+            }
+          }
+        } catch(parseErr) { /* skip unparseable lines */ }
+      }
+    }
+  } catch(e) {
+    status.textContent = 'Error: ' + e.message;
+    status.className = 'action-status fail';
+    addLogEntry('', `<strong>Connection error</strong>: ${e.message}`, 'fail');
+  }
+
+  btn.disabled = false;
