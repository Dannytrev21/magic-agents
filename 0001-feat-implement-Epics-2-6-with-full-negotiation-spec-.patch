+def _parse_sse_events(sse_text: str) -> list[dict]:
+    """Parse SSE text into a list of event dicts."""
+    events = []
+    for line in sse_text.split("\n"):
+        line = line.strip()
+        if line.startswith("data: "):
+            try:
+                data = json.loads(line[6:])
+                events.append(data)
+            except json.JSONDecodeError:
+                pass
+    return events
