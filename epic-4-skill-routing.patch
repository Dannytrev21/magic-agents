@@ -0,0 +1,171 @@
+"""Pytest Unit Test Skill — generates tagged pytest test files from spec contracts.
+
+Feature 4.2: Reads the spec contract (success, failures, invariants) and generates
+a complete pytest test file. Each test function is tagged with its spec ref for
+traceability back to AC checkboxes.
+
+Uses FastAPI's TestClient for API behavior requirements.
+"""
+
+import textwrap
+
+from verify.skills.framework import VerificationSkill, register_skill
+
+
+class PytestSkill(VerificationSkill):
+    """Generates pytest test files from spec contracts.
+
+    Each generated test includes:
+    - Spec ref in the docstring as [REQ-xxx.ref]
+    - Spec ref in the function name as test_REQ_xxx_ref
+    - TestClient-based assertions against the dummy app
+    """
+
+    skill_id = "pytest_unit_test"
+
+    def generate(self, spec: dict, requirement: dict, constitution: dict) -> str:
+        """Generate a complete pytest test file for a requirement."""
+        contract = requirement.get("contract", {})
+        req_id = requirement["id"]
+        interface = contract.get("interface", {})
+        method = interface.get("method", "GET").lower()
+        path = interface.get("path", "/")
+
+        lines = [
+            '"""Auto-generated verification tests from spec.',
+            f'Requirement: {req_id} — {requirement.get("title", "")}',
+            '"""',
+            "",
+            "from fastapi.testclient import TestClient",
+            "",
+            "from dummy_app.main import app",
+            "",
+            "client = TestClient(app)",
+            "",
+        ]
+
+        # ── Success test ──
+        success = contract.get("success", {})
+        if success:
+            lines.append(self._gen_success_test(req_id, method, path, success))
+
+        # ── Failure tests ──
+        for failure in contract.get("failures", []):
+            lines.append(self._gen_failure_test(req_id, method, path, failure))
+
+        # ── Invariant tests ──
+        for inv in contract.get("invariants", []):
+            forbidden = success.get("schema", {}).get("forbidden_fields", [])
+            lines.append(self._gen_invariant_test(req_id, method, path, inv, forbidden))
+
+        return "\n".join(lines)
+
+    def output_path(self, spec: dict, requirement: dict) -> str:
+        """Return the output path from the spec's verification block."""
+        for ver in requirement.get("verification", []):
+            if ver.get("output"):
+                return ver["output"]
+        # Fallback: derive from jira key
+        key = spec.get("meta", {}).get("jira_key", "UNKNOWN").lower().replace("-", "_")
+        return f".verify/generated/test_{key}.py"
+
+    # ── Private generators ──
+
+    def _gen_success_test(
+        self, req_id: str, method: str, path: str, success: dict,
+    ) -> str:
+        status = success.get("status", 200)
+        required_fields = success.get("schema", {}).get("required", [])
+        fields_check = " and ".join(f'"{f}" in body' for f in required_fields)
+        safe_req = _safe(req_id)
+
+        return textwrap.dedent(f'''\
+            def test_{safe_req}_success():
+                """[{req_id}.success] Happy path returns correct data."""
+                response = client.{method}("{path}", headers={{"Authorization": "Bearer valid-token"}})
+                assert response.status_code == {status}, (
+                    f"Expected {status}, got {{response.status_code}}"
+                )
+                body = response.json()
+                assert {fields_check}, f"Missing required fields in {{body}}"
+
+        ''')
+
+    def _gen_failure_test(
+        self, req_id: str, method: str, path: str, failure: dict,
+    ) -> str:
+        fid = failure["id"]
+        status = failure["status"]
+        error_key = failure.get("body", {}).get("error", "unknown")
+        violates = failure.get("violates", "")
+        safe_req = _safe(req_id)
+        safe_fid = _safe(fid)
+
+        # Determine request params based on which precondition is violated
+        if violates == "PRE-001":
+            # Auth failure — no auth header
+            request_line = f'response = client.{method}("{path}")'
+        elif violates == "PRE-002":
+            # Data existence failure — invalid user token
+            request_line = (
+                f'response = client.{method}("{path}", '
+                f'headers={{"Authorization": "Bearer not-found-user"}})'
+            )
+        else:
+            # Generic failure — no auth header
+            request_line = f'response = client.{method}("{path}")'
+
+        return textwrap.dedent(f'''\
+            def test_{safe_req}_{safe_fid}():
+                """[{req_id}.{fid}] {failure.get("when", fid)}"""
+                {request_line}
+                assert response.status_code == {status}, (
+                    f"Expected {status}, got {{response.status_code}}"
+                )
+                body = response.json()
+                assert body["detail"]["error"] == "{error_key}", (
+                    f"Expected error '{error_key}', got {{body}}"
+                )
+
+        ''')
+
+    def _gen_invariant_test(
+        self,
+        req_id: str,
+        method: str,
+        path: str,
+        invariant: dict,
+        forbidden_fields: list[str],
+    ) -> str:
+        inv_id = invariant["id"]
+        safe_req = _safe(req_id)
+        safe_inv = _safe(inv_id)
+
+        if forbidden_fields:
+            forbidden_checks = " and ".join(
+                f'"{f}" not in body' for f in forbidden_fields
+            )
+        else:
+            forbidden_checks = "True  # No forbidden fields specified"
+
+        return textwrap.dedent(f'''\
+            def test_{safe_req}_{safe_inv}():
+                """[{req_id}.{inv_id}] {invariant.get("rule", inv_id)}"""
+                response = client.{method}("{path}", headers={{"Authorization": "Bearer valid-token"}})
+                assert response.status_code == 200
+                body = response.json()
+                assert {forbidden_checks}, (
+                    f"Forbidden fields found in response: {{body.keys()}}"
+                )
+
+        ''')
+
+
+def _safe(name: str) -> str:
+    """Convert a spec ref like REQ-001 to a valid Python identifier."""
+    return name.replace("-", "_")
+
+
+# Auto-register on import
+_instance = PytestSkill()
+register_skill(_instance)
