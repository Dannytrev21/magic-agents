+++ b/src/verify/skills/tag_enforcer.py
@@ -0,0 +1,71 @@
+"""Tag Contract Enforcement — validates that generated tests cover all spec refs.
+
+Feature 4.3: Every generated test method must be tagged with its spec ref.
+This module scans generated test content and compares against expected refs
+from the spec's verification block.
+
+This is 100% deterministic — zero AI. It's a back-pressure mechanism from
+harness engineering: agents validate their own work before declaring success.
+"""
+
+import re
+
+
+def validate_tags(generated_content: str, expected_refs: list[str]) -> dict:
+    """Validate that generated test content covers all expected spec refs.
+
+    Scans for spec ref patterns in:
+    - Bracket notation: [REQ-001.success], [REQ-001.FAIL-001]
+    - Underscore notation: test_REQ_001_success, REQ_001_FAIL_001
+
+    Args:
+        generated_content: The generated test file content as a string.
+        expected_refs: List of expected spec refs (e.g., ['REQ-001.success', 'REQ-001.FAIL-001']).
+
+    Returns:
+        Dict with:
+            - covered: refs found in the content
+            - missing: refs NOT found in the content
+            - extra: refs found in content but NOT in expected list
+    """
+    found_refs = _extract_all_refs(generated_content)
+    expected_set = set(expected_refs)
+    found_set = set(found_refs)
+
+    covered = sorted(expected_set & found_set)
+    missing = sorted(expected_set - found_set)
+    extra = sorted(found_set - expected_set)
+
+    return {
+        "covered": covered,
+        "missing": missing,
+        "extra": extra,
+    }
+
+
+def _extract_all_refs(content: str) -> list[str]:
+    """Extract all spec ref tags from test content.
+
+    Looks for:
+    - [REQ-001.success] bracket patterns
+    - [REQ-001.FAIL-001] bracket patterns
+    - REQ_001_success underscore patterns (converted to dot notation)
+    """
+    refs = set()
+
+    # Pattern 1: bracket-enclosed refs like [REQ-001.success] or [REQ-001.FAIL-001]
+    bracket_matches = re.findall(r"\[([A-Z]+-\d+\.\S+?)\]", content)
+    refs.update(bracket_matches)
+
+    # Pattern 2: underscore-based refs in function names
+    # Convert REQ_001_success → REQ-001.success
+    # Convert REQ_001_FAIL_001 → REQ-001.FAIL-001
+    underscore_matches = re.findall(
+        r"(REQ_\d+)_(success|FAIL_\d+|INV_\d+)", content,
+    )
+    for req_part, element_part in underscore_matches:
+        req_ref = req_part.replace("_", "-")  # REQ_001 → REQ-001
+        element_ref = element_part.replace("_", "-")  # FAIL_001 → FAIL-001
+        refs.add(f"{req_ref}.{element_ref}")
+
+    return sorted(refs)
