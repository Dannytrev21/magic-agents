+"""Verification Skill Framework — base class, registry, and dispatcher.
+
+Feature 4.1: Plugin architecture where each verification skill is a self-contained module.
+Each skill follows the SKILL.md open standard for progressive disclosure.
+
+The routing table in compiler.py determines which skill handles which requirement type.
+This module provides the runtime dispatch mechanism.
+"""
+
+import logging
+import os
+from abc import ABC, abstractmethod
+
+logger = logging.getLogger(__name__)
+
+# ── Skill Registry ──
+# Maps skill_id → VerificationSkill instance
+SKILL_REGISTRY: dict[str, "VerificationSkill"] = {}
+
+
+class VerificationSkill(ABC):
+    """Base class for all verification skills.
+
+    Each skill generates proof-of-correctness artifacts (tests, configs, scenarios)
+    from a spec contract. Skills are dispatched by the routing table in compiler.py.
+    """
+
+    skill_id: str = ""
+
+    @abstractmethod
+    def generate(self, spec: dict, requirement: dict, constitution: dict) -> str:
+        """Generate the verification artifact content.
+
+        Args:
+            spec: The full spec dict (from .verify/specs/*.yaml)
+            requirement: The specific requirement dict from spec['requirements']
+            constitution: Repository constitution dict (coding patterns, tech stack)
+
+        Returns:
+            The generated artifact content as a string.
+        """
+        ...
+
+    @abstractmethod
+    def output_path(self, spec: dict, requirement: dict) -> str:
+        """Return where the artifact should be written.
+
+        Args:
+            spec: The full spec dict
+            requirement: The specific requirement dict
+
+        Returns:
+            File path string for the output artifact.
+        """
+        ...
+
+
+def register_skill(skill: VerificationSkill) -> None:
+    """Register a skill in the global SKILL_REGISTRY."""
+    if not skill.skill_id:
+        raise ValueError(f"Skill {type(skill).__name__} has no skill_id")
+    SKILL_REGISTRY[skill.skill_id] = skill
+    logger.info(f"Registered verification skill: {skill.skill_id}")
+
+
+def dispatch_skills(spec: dict, constitution: dict) -> dict[str, str]:
+    """Dispatch verification skills for all requirements in a spec.
+
+    Reads the 'verification' blocks from each requirement, looks up each skill
+    in SKILL_REGISTRY, calls generate(), and writes the output file.
+
+    Args:
+        spec: The full spec dict
+        constitution: Repository constitution dict
+
+    Returns:
+        Dict mapping {output_path: generated_content} for all generated files.
+    """
+    results: dict[str, str] = {}
+
+    for requirement in spec.get("requirements", []):
+        for verification in requirement.get("verification", []):
+            skill_id = verification.get("skill")
+            output = verification.get("output")
+
+            if not skill_id:
+                logger.warning(
+                    f"Requirement {requirement['id']} has no skill specified"
+                )
+                continue
+
+            skill = SKILL_REGISTRY.get(skill_id)
+            if skill is None:
+                logger.warning(
+                    f"No skill registered for '{skill_id}' "
+                    f"(requirement {requirement['id']})"
+                )
+                continue
+
+            # Generate the artifact
+            content = skill.generate(spec, requirement, constitution)
+
+            # Determine output path
+            if output:
+                path = output
+            else:
+                path = skill.output_path(spec, requirement)
+
+            # Write to disk
+            os.makedirs(os.path.dirname(path), exist_ok=True)
+            with open(path, "w") as f:
+                f.write(content)
+
+            results[path] = content
+            logger.info(
+                f"Generated {path} via skill '{skill_id}' "
+                f"for requirement {requirement['id']}"
+            )
+
+    return results
