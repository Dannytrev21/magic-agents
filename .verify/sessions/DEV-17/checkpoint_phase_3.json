  "preconditions": [
    {
      "id": "PRE-001",
      "description": "Valid JWT bearer token is present",
      "formal": "jwt != null AND jwt.exp > now()",
      "category": "authentication"
    },
    {
      "id": "PRE-002",
      "description": "Request contains properly formatted Authorization header",
      "formal": "request.headers['Authorization'].startsWith('Bearer ')",
      "category": "authentication"
    },
    {
      "id": "PRE-003",
      "description": "User referenced in JWT exists in the system",
      "formal": "db.users.exists(jwt.sub) == true",
      "category": "data_existence"
    },
    {
      "id": "PRE-004",
      "description": "User account is in active state",
      "formal": "db.users.find(jwt.sub).status == 'active'",
      "category": "data_state"
    },
    {
      "id": "PRE-005",
      "description": "User has authorization to access dog data",
      "formal": "jwt.scope.includes('read:dogs') OR user.permissions.includes('dogs:read')",
      "category": "authorization"
    },
    {
      "id": "PRE-006",
      "description": "Database connection is available",
      "formal": "db.connection.status == 'healthy'",
      "category": "system_health"
    },
    {
      "id": "PRE-007",
      "description": "Rate limit for user has not been exceeded",
      "formal": "rate_limiter.check(jwt.sub, 'get_dogs') == allowed",
      "category": "rate_limit"
    }
  ],
